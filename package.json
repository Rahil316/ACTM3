{
  "name": "token-wand",
  "version": "1.0.0",
  "description": "Token Wand — Color Token System for Figma",
  "main": "code.js",
  "scripts": {
    "_comment_build": "── Build ────────────────────────────────────────────────────────────",
    "build": "tsx scripts/generateThemeCss.ts && tsx scripts/build-presets.ts && node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && vite build && node scripts/plugin.js dist",
    "build:release": "tsx scripts/generateThemeCss.ts && tsx scripts/build-presets.ts --release && node -e \"require('fs').rmSync('dist-release',{recursive:true,force:true})\" && VITE_OUT_DIR=dist-release vite build && node scripts/plugin.js dist-release --manifest",
    "build:plugin": "node scripts/plugin.js dist",
    "build:plugin:release": "node scripts/plugin.js dist-release --manifest",
    "_comment_dev": "── Dev ──────────────────────────────────────────────────────────────",
    "dev": "VITE_DEV=true vite",
    "_comment_watch": "── Watch ────────────────────────────────────────────────────────────",
    "watch": "node scripts/plugin.js dist --watch & node scripts/watch-ui.js",
    "watch:release": "node scripts/plugin.js dist-release --watch --manifest & node scripts/watch-ui.js --release",
    "_comment_theme": "── Theme ────────────────────────────────────────────────────────────",
    "theme:gen": "tsx scripts/generateThemeCss.ts",
    "_comment_qa": "── QA ───────────────────────────────────────────────────────────────",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "npm run typecheck && npm run lint && npm run test",
    "_comment_release": "── Release ──────────────────────────────────────────────────────────",
    "release": "node package.js",
    "release:patch": "node package.js patch",
    "release:flag": "node package.js flag",
    "_comment_storybook": "── Storybook ────────────────────────────────────────────────────────",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build"
  },
  "author": "",
  "license": "",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "clsx": "^2.1.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "^9.39.4",
    "@figma/eslint-plugin-figma-plugins": "*",
    "@figma/plugin-typings": "^1.124.0",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.4",
    "eslint-plugin-storybook": "^10.4.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "storybook": "^10.4.1",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^7.0.0",
    "vite-plugin-singlefile": "^2.0.2",
    "vitest": "^4.1.7"
  }
}
