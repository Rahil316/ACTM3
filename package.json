{
  "name": "ctm316Fig",
  "version": "1.0.0",
  "description": "Your Figma Plugin",
  "main": "code.js",
  "scripts": {
    "prebuild": "node -e \"if (!require('fs').existsSync('./node_modules') || !require('fs').existsSync('./node_modules/tailwindcss')) { console.log('Missing dependencies. Running npm install...'); require('child_process').execSync('npm install', {stdio: 'inherit'}); }\"",
    "prewatch": "npm run prebuild",
    "build": "node build.js",
    "watch": "node watch.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release": "node package.js",
    "release:patch": "node package.js patch",
    "release:flag": "node package.js flag"
  },
  "author": "",
  "license": "",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@figma/eslint-plugin-figma-plugins": "*",
    "@figma/plugin-typings": "^1.124.0",
    "eslint": "^9.39.4",
    "tailwindcss": "^3.4.19"
  }
}
