{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["ES2017"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "outDir": "dist-plugin-tmp",
    "baseUrl": "."
  },
  "include": ["src/plugin/**/*"],
  "exclude": ["node_modules", "vanilla_archive"]
}
