{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "outDir": "../../dist-plugin-tmp",
    "baseUrl": ".",
    "types": ["@figma/plugin-typings"]
  },
  "include": ["**/*"],
  "exclude": ["__tests__/**/*"]
}
